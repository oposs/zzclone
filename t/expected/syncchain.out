zfs send -I 's1' 'tank/data/a@s3' | mbuffer -m 1G | zfs receive -u 'back/data/a' && \
zfs send 'tank/data/c@s1' | mbuffer -m 1G | zfs receive -u 'back/data/c@s1' && \
zfs send -I 's1' 'tank/data/c@s2' | mbuffer -m 1G | zfs receive -u 'back/data/c' && \
zfs send -I 's1' 'tank/data/d@s2' | mbuffer -m 1G | zfs receive -u 'back/data/d'
exit=0
