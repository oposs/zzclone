zfs send -I 's1' 'tank/data/a@s3' | mbuffer -m 1G | zfs receive -s -u 'back/data/a' && \
zfs send 'tank/data/c@s1' | mbuffer -m 1G | zfs receive -s -u 'back/data/c@s1' && \
zfs send -I 's1' 'tank/data/c@s2' | mbuffer -m 1G | zfs receive -s -u 'back/data/c' && \
zfs send -t 'TOKEN123' | mbuffer -m 1G | zfs receive -s -u 'back/data/d'
exit=0
