zfs rollback -r 'back/data/a@s1' && \
zfs send -v -I 's1' 'tank/data/a@s3' | mbuffer -m 1G | zfs receive -s -u 'back/data/a' && \
zfs send -v 'tank/data/c@s1' | mbuffer -m 1G | zfs receive -s -F -u 'back/data/c@s1' && \
zfs send -v -I 's1' 'tank/data/c@s2' | mbuffer -m 1G | zfs receive -s -u 'back/data/c' && \
zfs send -v -t 'TOKEN123' | mbuffer -m 1G | zfs receive -s -u 'back/data/d'
exit=0
