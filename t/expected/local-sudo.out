# tank/data - up to date
sudo zfs send -I 's1' 'tank/data/a@s3' | mbuffer -m 1G | sudo zfs receive -u 'back/data/a'
# skipping tank/data/b - no snapshots
# tank/data/c - no common snapshot, full send
sudo zfs send 'tank/data/c@s1' | mbuffer -m 1G | sudo zfs receive -u 'back/data/c@s1'
sudo zfs send -I 's1' 'tank/data/c@s2' | mbuffer -m 1G | sudo zfs receive -u 'back/data/c'
sudo zfs send -I 's1' 'tank/data/d@s2' | mbuffer -m 1G | sudo zfs receive -u 'back/data/d'
# tank/data/e - up to date
exit=0
